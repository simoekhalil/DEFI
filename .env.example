# Gala Launchpad QA Testing - Environment Configuration
# Copy this file to .env and fill in your values

# Base URL for the Gala Launchpad
BASE_URL=https://lpad-frontend-dev1.defi.gala.com

# MetaMask wallet private key (without 0x prefix)
# NEVER commit the actual .env file with your real private key!
METAMASK_PRIVATE_KEY=your_private_key_here_without_0x_prefix

# Optional: Custom network configuration
# Uncomment and set these if testing on a different network
# RPC_URL=https://your-rpc-url.com
# CHAIN_ID=1234
# CHAIN_NAME=Your Chain Name
# CHAIN_SYMBOL=ETH

# Optional: Jira integration for bug reporting
# Only needed if you want to create Jira tickets from scripts
# JIRA_BASE_URL=https://your-company.atlassian.net
# JIRA_EMAIL=your-email@example.com
# JIRA_API_TOKEN=your_jira_api_token
# JIRA_PROJECT_KEY=YOUR_PROJECT
